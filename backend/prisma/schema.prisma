generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pin {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String
  lat       Float
  lng       Float
  cor       String   @default("#ffd500")
  data      DateTime @default(now())
}
